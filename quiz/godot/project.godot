; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="Quiz Offline"
run/main_scene="res://main.tscn"
config/features=PackedStringArray("4.6")

[autoload]

AppState="*res://autoload/app_state.gd"
ShowConfig="*res://autoload/show_config.gd"
ContentRepo="*res://autoload/content_repo.gd"
GameService="*res://autoload/game_service.gd"
MqttBus="*res://autoload/mqtt_bus.tscn"

[display]

window/size/viewport_width=1920
window/size/viewport_height=1200
window/stretch/mode="canvas_items"
window/stretch/aspect="expand"
window/handheld/orientation=5
