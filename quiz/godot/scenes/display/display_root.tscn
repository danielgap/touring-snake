[gd_scene format=3]

[ext_resource type="Script" path="res://scripts/display/display_controller.gd" id="1_script"]

[node name="DisplayRoot" type="Control"]
layout_mode = 3
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2
script = ExtResource("1_script")

[node name="MarginContainer" type="MarginContainer" parent="."]
layout_mode = 1
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2
theme_override_constants/margin_left = 24
theme_override_constants/margin_top = 24
theme_override_constants/margin_right = 24
theme_override_constants/margin_bottom = 24

[node name="VBoxContainer" type="VBoxContainer" parent="MarginContainer"]
layout_mode = 2
theme_override_constants/separation = 14

[node name="TitleLabel" type="Label" parent="MarginContainer/VBoxContainer"]
layout_mode = 2
theme_override_font_sizes/font_size = 28
text = "Pantalla principal"

[node name="PhaseLabel" type="Label" parent="MarginContainer/VBoxContainer"]
layout_mode = 2
theme_override_font_sizes/font_size = 24
text = "Estado de juego"

[node name="StatusLabel" type="Label" parent="MarginContainer/VBoxContainer"]
layout_mode = 2
autowrap_mode = 3
theme_override_font_sizes/font_size = 18

[node name="QuestionSectionLabel" type="Label" parent="MarginContainer/VBoxContainer"]
layout_mode = 2
text = "Pregunta"

[node name="QuestionLabel" type="Label" parent="MarginContainer/VBoxContainer"]
layout_mode = 2
autowrap_mode = 3
theme_override_font_sizes/font_size = 24
text = "Esperando pregunta"

[node name="LockLabel" type="Label" parent="MarginContainer/VBoxContainer"]
layout_mode = 2
autowrap_mode = 3
text = "Estado de respuesta"

[node name="TeamLocksLabel" type="Label" parent="MarginContainer/VBoxContainer"]
layout_mode = 2
autowrap_mode = 3
text = "Estado de equipos"

[node name="FeedbackLabel" type="Label" parent="MarginContainer/VBoxContainer"]
layout_mode = 2
autowrap_mode = 3
theme_override_font_sizes/font_size = 20
text = "Feedback"

[node name="OptionsSectionLabel" type="Label" parent="MarginContainer/VBoxContainer"]
layout_mode = 2
text = "Opciones"

[node name="OptionsVBox" type="VBoxContainer" parent="MarginContainer/VBoxContainer"]
layout_mode = 2
