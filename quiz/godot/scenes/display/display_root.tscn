[node name="OptionBLabel" type="Label" parent="MarginContainer/VBoxContainer/OptionsVBox"]
layout_mode = 2
text = "B) --"

[node name="OptionCLabel" type="Label" parent="MarginContainer/VBoxContainer/OptionsVBox"]
layout_mode = 2
text = "C) --"

[node name="OptionDLabel" type="Label" parent="MarginContainer/VBoxContainer/OptionsVBox"]
layout_mode = 2
