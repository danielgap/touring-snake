[gd_scene format=3]

[ext_resource type="Script" path="res://scripts/contestant/contestant_controller.gd" id="1_script"]

[node name="ContestantRoot" type="Control"]
layout_mode = 3
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2
script = ExtResource("1_script")

[node name="Background" type="ColorRect" parent="."]
layout_mode = 1
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2
color = Color(0.024, 0.039, 0.071, 1)

[node name="RootMargin" type="MarginContainer" parent="."]
layout_mode = 1
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2
theme_override_constants/margin_left = 24
theme_override_constants/margin_top = 20
theme_override_constants/margin_right = 24
theme_override_constants/margin_bottom = 20

[node name="RootVBox" type="VBoxContainer" parent="RootMargin"]
layout_mode = 2
theme_override_constants/separation = 16

[node name="HeaderBar" type="HBoxContainer" parent="RootMargin/RootVBox"]
layout_mode = 2
theme_override_constants/separation = 12

[node name="TeamBadge" type="PanelContainer" parent="RootMargin/RootVBox/HeaderBar"]
unique_name_in_owner = true
layout_mode = 2

[node name="TeamPad" type="MarginContainer" parent="RootMargin/RootVBox/HeaderBar/TeamBadge"]
layout_mode = 2
theme_override_constants/margin_left = 28
theme_override_constants/margin_top = 14
theme_override_constants/margin_right = 28
theme_override_constants/margin_bottom = 14

[node name="TeamName" type="Label" parent="RootMargin/RootVBox/HeaderBar/TeamBadge/TeamPad"]
unique_name_in_owner = true
layout_mode = 2
theme_override_font_sizes/font_size = 30
theme_override_colors/font_color = Color(1, 1, 1, 1)
text = "EQUIPO 1"

[node name="HeaderSpacer" type="Control" parent="RootMargin/RootVBox/HeaderBar"]
layout_mode = 2
size_flags_horizontal = 3

[node name="StatusBadge" type="PanelContainer" parent="RootMargin/RootVBox/HeaderBar"]
unique_name_in_owner = true
layout_mode = 2

[node name="StatusPad" type="MarginContainer" parent="RootMargin/RootVBox/HeaderBar/StatusBadge"]
layout_mode = 2
theme_override_constants/margin_left = 24
theme_override_constants/margin_top = 14
theme_override_constants/margin_right = 24
theme_override_constants/margin_bottom = 14

[node name="StatusLabel" type="Label" parent="RootMargin/RootVBox/HeaderBar/StatusBadge/StatusPad"]
unique_name_in_owner = true
layout_mode = 2
theme_override_font_sizes/font_size = 22
theme_override_colors/font_color = Color(1, 1, 1, 1)
text = "ESPERANDO"

[node name="QuestionCard" type="PanelContainer" parent="RootMargin/RootVBox"]
unique_name_in_owner = true
layout_mode = 2
size_flags_vertical = 3
size_flags_stretch_ratio = 0.4

[node name="QPad" type="MarginContainer" parent="RootMargin/RootVBox/QuestionCard"]
layout_mode = 2
theme_override_constants/margin_left = 24
theme_override_constants/margin_top = 20
theme_override_constants/margin_right = 24
theme_override_constants/margin_bottom = 20

[node name="QuestionLabel" type="Label" parent="RootMargin/RootVBox/QuestionCard/QPad"]
unique_name_in_owner = true
layout_mode = 2
theme_override_font_sizes/font_size = 28
theme_override_colors/font_color = Color(0.902, 0.929, 0.953, 1)
autowrap_mode = 3
text = "Esperando pregunta del presentador..."

[node name="AnswersGrid" type="GridContainer" parent="RootMargin/RootVBox"]
visible = false
layout_mode = 2
size_flags_vertical = 3
size_flags_stretch_ratio = 1.0
columns = 2
theme_override_constants/h_separation = 16
theme_override_constants/v_separation = 16

[node name="AnswerA" type="Button" parent="RootMargin/RootVBox/AnswersGrid"]
unique_name_in_owner = true
layout_mode = 2
custom_minimum_size = Vector2(0, 120)
size_flags_horizontal = 3
size_flags_vertical = 3
theme_override_font_sizes/font_size = 26
text = "A) --"

[node name="AnswerB" type="Button" parent="RootMargin/RootVBox/AnswersGrid"]
unique_name_in_owner = true
layout_mode = 2
custom_minimum_size = Vector2(0, 120)
size_flags_horizontal = 3
size_flags_vertical = 3
theme_override_font_sizes/font_size = 26
text = "B) --"

[node name="AnswerC" type="Button" parent="RootMargin/RootVBox/AnswersGrid"]
unique_name_in_owner = true
layout_mode = 2
custom_minimum_size = Vector2(0, 120)
size_flags_horizontal = 3
size_flags_vertical = 3
theme_override_font_sizes/font_size = 26
text = "C) --"

[node name="AnswerD" type="Button" parent="RootMargin/RootVBox/AnswersGrid"]
unique_name_in_owner = true
layout_mode = 2
custom_minimum_size = Vector2(0, 120)
size_flags_horizontal = 3
size_flags_vertical = 3
theme_override_font_sizes/font_size = 26
text = "D) --"

[node name="FeedbackCard" type="PanelContainer" parent="RootMargin/RootVBox"]
unique_name_in_owner = true
layout_mode = 2

[node name="FBPad" type="MarginContainer" parent="RootMargin/RootVBox/FeedbackCard"]
layout_mode = 2
theme_override_constants/margin_left = 20
theme_override_constants/margin_top = 14
theme_override_constants/margin_right = 20
theme_override_constants/margin_bottom = 14

[node name="FeedbackLabel" type="Label" parent="RootMargin/RootVBox/FeedbackCard/FBPad"]
unique_name_in_owner = true
layout_mode = 2
theme_override_font_sizes/font_size = 22
theme_override_colors/font_color = Color(0.902, 0.929, 0.953, 1)
autowrap_mode = 3
